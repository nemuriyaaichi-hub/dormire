ENVIRONMENT=development
DEBUG=True
DJANGO_ALLOWED_HOSTS=*
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000
DJANGO_CORS_ALLOW_ALL_ORIGINS=True
DJANGO_CORS_ALLOWED_ORIGINS=

# Local development
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nemuriya

# uwsgi param
UWSGI_WORKERS=3

# docker param
COMPOSE_PROJECT_NAME=nemuriya

# security
ADMIN_AUTO_CREATE=True
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin

# port
MINIO_CLIENT_PORT=9000
MINIO_CLIENT_CONSOLE_PORT=9001

# s3
AWS_S3_ACCESS_KEY_ID=minio-key
AWS_S3_SECRET_ACCESS_KEY=minio-secret
AWS_STORAGE_BUCKET_NAME=nemuriya-test
AWS_S3_REGION_NAME=ap-northeast-1
AWS_S3_SPECIFY_ENDPOINT_URL=True
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_SPECIFY_CUSTOM_DOMAIN=True
AWS_S3_CUSTOM_DOMAIN=localhost:${MINIO_CLIENT_PORT}/${AWS_STORAGE_BUCKET_NAME}
AWS_S3_URL_PROTOCOL=http:
AWS_QUETYSTRING_AUTH=False

# AWS SES
USE_SMTP_BACKEND=False
SMTP_HOST=email-smtp.ap-northeast-1.amazonaws.com
SMTP_USERNAME=username
SMTP_PASSWORD=password
NEMURIYA_EMAIL="Dormire運営事務局<admin@example.com>"
NEMURIYA_LINE_URL=https://line.me/ja/xxxxx/
NEMURIYA_BCC=bcc@example.com
NEMURIYA_CONTACT_EMAIL=contact@example.com
DORMIRE_IOS_APP_URL=https://apps.apple.com/jp/app/xxxx/xxxxxxxx
