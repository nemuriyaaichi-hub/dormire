server {
    server_name api.dormire.jp;

    location = /favicon.ico { access_log off; log_not_found off; }

    #location /static/ {
    #    root /var/www/api/nemuriya-backend;
    #}

    location / {
        include proxy_params;
        proxy_pass http://unix:/var/www/api/nemuriya-backend/api.sock;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/api.dormire.jp/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/api.dormire.jp/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot



}

server {
    if ($host = api.dormire.jp) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name api.dormire.jp;
    return 404; # managed by Certbot


}